APP_NAME="AI 家装一键成片系统"
APP_ENV=local
APP_BASE_URL=http://127.0.0.1:8000
SECRET_KEY=change-me

# OpenAI / GPT structured design and optional TTS.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_TTS_MODEL=

# DeepSeek compatible example:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# Taobao Alliance TOP/TBK.
TBK_APP_KEY=
TBK_APP_SECRET=
TBK_ADZONE_ID=
TBK_PID=
TBK_SITE_ID=
TBK_API_URL=https://eco.taobao.com/router/rest
TBK_MIN_COMMISSION_RATE=1000
TBK_MIN_SALES=20
TBK_STRICT_FILTERS=false

# Optional render/image provider. demo creates local visual mockups.
RENDER_PROVIDER=demo
RENDER_API_URL=
RENDER_API_KEY=

# Video / exports.
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
LOG_RETENTION_DAYS=180
RATE_LIMIT_PER_MINUTE=20
